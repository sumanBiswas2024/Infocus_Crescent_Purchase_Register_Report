<mvc:View
    controllerName="purchaseregisterreport.controller.PurchaseRegister"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:ui="sap.ui.table"
    xmlns:core="sap.ui.core"
>
    <f:DynamicPage
        id="dynamicPageId"
        headerExpanded="true"
        showFooter="false"
    >
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title
                        text="Standard"
                        level="H2"
                    />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <fb:FilterBar
                    id="filterBar"
                    search=".onSearch"
                    showClearOnFB="true"
                    useToolbar="false"
                    clear=".onClear"
                    filterChange=".onFilterChange"
                >
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem
                            groupName="G1"
                            name="PoDateFrom"
                            label="From PO Date"
                            visibleInFilterBar="true"
                            mandatory="true"
                        >
                            <fb:control>
                                <DatePicker
                                    id="filterPoDateFrom"
                                    valueFormat="yyyy-MM-dd"
                                    displayFormat="dd.MM.yyyy"
                                    tooltip="Select Start Date for Purchase Order"
                                    change=".onDateChange"
                                />
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem
                            groupName="G1"
                            name="PoDateTo"
                            label="To PO Date"
                            visibleInFilterBar="true"
                            mandatory="true"
                        >
                            <fb:control>
                                <DatePicker
                                    id="filterPoDateTo"
                                    valueFormat="yyyy-MM-dd"
                                    displayFormat="dd.MM.yyyy"
                                    tooltip="Select End Date for Purchase Order"
                                    change=".onDateChange"
                                />
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem
                            groupName="G1"
                            name="Pr"
                            label="Purchase Requisition No."
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <MultiInput
                                    id="filterPr"
                                    showValueHelp="true"
                                    valueHelpRequest=".onValueHelpRequest"
                                    tooltip="Enter Purchase Requisition Number"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="type"
                                            value="string"
                                        />
                                    </customData>
                                </MultiInput>
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem
                            groupName="G1"
                            name="PrDate"
                            label="PR Date"
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <MultiInput
                                    id="filterPrDate"
                                    showValueHelp="true"
                                    valueHelpRequest=".onValueHelpRequest"
                                    tooltip="Enter Purchase Requisition Creation Date"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="type"
                                            value="date"
                                        />
                                    </customData>
                                </MultiInput>
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem
                            groupName="G1"
                            name="Po"
                            label="PO No."
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <MultiInput
                                    id="filterPo"
                                    showValueHelp="true"
                                    valueHelpRequest=".onValueHelpRequest"
                                    tooltip="Enter Purchase Order Number"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="type"
                                            value="string"
                                        />
                                    </customData>
                                </MultiInput>
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem
                            groupName="G1"
                            name="Material"
                            label="Material Code"
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <MultiInput
                                    id="filterMaterial"
                                    showValueHelp="true"
                                    valueHelpRequest=".onValueHelpRequest"
                                    tooltip="Enter Material Number"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="type"
                                            value="string"
                                        />
                                    </customData>
                                </MultiInput>
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem
                            groupName="G1"
                            name="Plant"
                            label="PO Plant"
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <MultiInput
                                    id="filterPlant"
                                    showValueHelp="true"
                                    valueHelpRequest=".onValueHelpRequest"
                                    tooltip="Enter Plant Code"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="type"
                                            value="string"
                                        />
                                    </customData>
                                </MultiInput>
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem
                            groupName="G1"
                            name="GateEntry"
                            label="Gate Entry No."
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <MultiInput
                                    id="filterGateEntry"
                                    showValueHelp="true"
                                    valueHelpRequest=".onValueHelpRequest"
                                    tooltip="Enter Gate Entry Document Number"
                                >
                                    <customData>
                                        <core:CustomData
                                            key="type"
                                            value="string"
                                        />
                                    </customData>
                                </MultiInput>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <ui:Table
                id="purchaseRegisterTable"
                selectionMode="MultiToggle"
                visibleRowCountMode="Auto"
                rowActionCount="1"
            >
                <ui:extension>
                    <Toolbar>
                        <Title
                            id="tableHeaderTitle"
                            text="Purchase Register (0)"
                            level="H2"
                        />
                        <ToolbarSpacer />
                        <Button
                            icon="sap-icon://excel-attachment"
                            tooltip="Export"
                            press=".onExportExcel"
                        />
                        <Button
                            icon="sap-icon://action-settings"
                            tooltip="Settings"
                            press=".onTableSettings"
                        />
                    </Toolbar>
                </ui:extension>

                <ui:columns>
                    <ui:Column width="11rem">
                        <Label
                            text="Purchase Requisition No."
                            tooltip="Purchase Requisition Document Number"
                        />
                        <ui:template>
                            <Text text="{Pr}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="11rem">
                        <Label
                            text="Purchase Requisition Item No."
                            tooltip="Item Number of Purchase Requisition"
                        />
                        <ui:template>
                            <Text text="{Pritm}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="6rem">
                        <Label
                            text="PR Plant"
                            tooltip="Purchase Requisition Plant Code"
                        />
                        <ui:template>
                            <Text text="{Prplant}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="12rem">
                        <Label
                            text="PR Plant Name"
                            tooltip="Purchase Requisition Plant Name"
                        />
                        <ui:template>
                            <Text text="{Prplantname}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="PR Date"
                            tooltip="Purchase Requisition Creation Date"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'PurchaseReqnCreationDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="9rem">
                        <Label
                            text="PR release date"
                            tooltip="Purchase Requisition Release Date"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'Prreldt', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="7rem">
                        <Label
                            text="PR Qty"
                            tooltip="Requested Purchase Requisition Quantity"
                        />
                        <ui:template>
                            <Text text="{RequestedQuantity}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="15rem">
                        <Label
                            text="PR Item Text"
                            tooltip="Purchase Requisition Item Short Text"
                        />
                        <ui:template>
                            <Text text="{Prtext}" />
                        </ui:template>
                    </ui:Column>

                    <ui:Column width="9rem">
                        <Label
                            text="PO No."
                            tooltip="Purchase Order Document Number"
                        />
                        <ui:template>
                            <Text text="{Po}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="7rem">
                        <Label
                            text="PO Item No."
                            tooltip="Item Number of Purchase Order"
                        />
                        <ui:template>
                            <Text text="{Poitm}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="10rem">
                        <Label
                            text="Material Code"
                            tooltip="Material Document Code"
                        />
                        <ui:template>
                            <Text text="{Material}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="6rem">
                        <Label
                            text="PO Plant"
                            tooltip="Purchase Order Plant Code"
                        />
                        <ui:template>
                            <Text text="{Plant}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="12rem">
                        <Label
                            text="PO Plant Name"
                            tooltip="Purchase Order Plant Name"
                        />
                        <ui:template>
                            <Text text="{PlantName}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="15rem">
                        <Label
                            text="Material Description"
                            tooltip="Purchase Order Material Short Text"
                        />
                        <ui:template>
                            <Text text="{PurchaseOrderItemText}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="15rem">
                        <Label
                            text="PO Item Text"
                            tooltip="Purchase Order Material Long Text"
                        />
                        <ui:template>
                            <Text text="{Potext}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="Vendor Code"
                            tooltip="Supplier / Vendor Code"
                        />
                        <ui:template>
                            <Text text="{Supplier}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="15rem">
                        <Label
                            text="Vendor Name"
                            tooltip="Supplier Full Name"
                        />
                        <ui:template>
                            <Text text="{SupplierFullName}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="PO Date"
                            tooltip="Purchase Order Creation Date"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'PurchaseOrderDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="9rem">
                        <Label
                            text="PO Release date"
                            tooltip="Purchase Order Release Date"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'Poreldate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="7rem">
                        <Label
                            text="PO Qty"
                            tooltip="Ordered Purchase Order Quantity"
                        />
                        <ui:template>
                            <Text text="{OrderQuantity}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="5rem">
                        <Label
                            text="UOM"
                            tooltip="Unit of Measure Code"
                        />
                        <ui:template>
                            <Text text="{UnitOfMeasure}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="10rem">
                        <Label
                            text="UOM Description"
                            tooltip="Unit of Measurement Long Text"
                        />
                        <ui:template>
                            <Text text="{UnitOfMeasureLongName}" />
                        </ui:template>
                    </ui:Column>

                    <ui:Column width="9rem">
                        <Label
                            text="GRN No."
                            tooltip="Goods Receipt Note / Material Document Number"
                        />
                        <ui:template>
                            <Text text="{Grn}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="6rem">
                        <Label
                            text="GRN Year"
                            tooltip="Material Document Year"
                        />
                        <ui:template>
                            <Text text="{Grnyr}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="6rem">
                        <Label
                            text="GRN Item"
                            tooltip="Material Document Item Number"
                        />
                        <ui:template>
                            <Text text="{Grnitm}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="GRN Date"
                            tooltip="GRN Posting Date in the Document"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'PostingDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="7rem">
                        <Label
                            text="GRN Qty"
                            tooltip="Quantity in Entry Unit for GRN"
                        />
                        <ui:template>
                            <Text text="{QuantityInEntryUnit}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="9rem">
                        <Label
                            text="GRN Amount"
                            tooltip="GRN Amount in Company Code Currency"
                        />
                        <ui:template>
                            <Text text="{PurOrdAmountInCompanyCodeCrcy1}" />
                        </ui:template>
                    </ui:Column>

                    <ui:Column width="9rem">
                        <Label
                            text="Gate Entry No."
                            tooltip="Inward Gate Entry Number"
                        />
                        <ui:template>
                            <Text text="{YY1_GateEntryNumber_MMI}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="9rem">
                        <Label
                            text="Gate Entry Date"
                            tooltip="Gate Entry Creation Date"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'gateentrydate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="9rem">
                        <Label
                            text="Gate Entry Qty"
                            tooltip="Challan Quantity at Gate Entry"
                        />
                        <ui:template>
                            <Text text="{YY1_ChallanQuantity_MMI}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="QC Status"
                            tooltip="Quality Control Status"
                        />
                        <ui:template>
                            <Text text="{Qcsta}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="6rem">
                        <Label
                            text="BY Hand"
                            tooltip="Delivered By Hand Indicator"
                        />
                        <ui:template>
                            <Text text="{byhand}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="10rem">
                        <Label
                            text="Vehicle No."
                            tooltip="Transport Vehicle Registration Number"
                        />
                        <ui:template>
                            <Text text="{YY1_VehicleNumber_MMI}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="12rem">
                        <Label
                            text="Transporter Name"
                            tooltip="Name of the Transporter"
                        />
                        <ui:template>
                            <Text text="{transportername}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="10rem">
                        <Label
                            text="Drivers Name"
                            tooltip="Name of the Vehicle Driver"
                        />
                        <ui:template>
                            <Text text="{drivername}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="Tare Weight"
                            tooltip="Tare Weight of Vehicle"
                        />
                        <ui:template>
                            <Text text="{YY1_TareWeight_MMI}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="Unit of Weight"
                            tooltip="Unit of Measurement for Weight"
                        />
                        <ui:template>
                            <Text text="{unitwt}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="Gross Weight"
                            tooltip="Gross Weight of Vehicle"
                        />
                        <ui:template>
                            <Text text="{YY1_GrossWeight_MMI}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="Net weight"
                            tooltip="Calculated Net Weight"
                        />
                        <ui:template>
                            <Text text="{YY1_NetWeight_MMI}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="9rem">
                        <Label
                            text="Check-in-Date"
                            tooltip="Gate Check-In Date"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'chkindt', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="Check-In-Time"
                            tooltip="Gate Check-In Time"
                        />
                        <ui:template>
                            <Text text="{chkintm}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="9rem">
                        <Label
                            text="Check-out-Date"
                            tooltip="Gate Check-Out Date"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'chkoutdt', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="Check-out-Time"
                            tooltip="Gate Check-Out Time"
                        />
                        <ui:template>
                            <Text text="{chkouttm}" />
                        </ui:template>
                    </ui:Column>

                    <ui:Column width="10rem">
                        <Label
                            text="GL Account No."
                            tooltip="General Ledger Account Number"
                        />
                        <ui:template>
                            <Text text="{GLAccount}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="12rem">
                        <Label
                            text="GL Description"
                            tooltip="General Ledger Account Long Name"
                        />
                        <ui:template>
                            <Text text="{GLAccountLongName}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="10rem">
                        <Label
                            text="WBS No."
                            tooltip="Work Breakdown Structure Number"
                        />
                        <ui:template>
                            <Text text="{wbs}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="12rem">
                        <Label
                            text="WBS Description"
                            tooltip="WBS Element Description"
                        />
                        <ui:template>
                            <Text text="{wbsdesc}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="12rem">
                        <Label
                            text="Invoice Posting Number"
                            tooltip="Accounting Document Number for Invoice"
                        />
                        <ui:template>
                            <Text text="{supinv}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="Condition Type"
                            tooltip="Pricing Condition Type"
                        />
                        <ui:template>
                            <Text text="{condtype}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="10rem">
                        <Label
                            text="Invoice Posting Date"
                            tooltip="Posting Date in the Document"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'invpostdt', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="14rem">
                        <Label
                            text="Vendor Invoice / Reference No."
                            tooltip="Reference Document Number from Vendor"
                        />
                        <ui:template>
                            <Text text="{SupplierInvoiceIDByInvcgParty}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="10rem">
                        <Label
                            text="Vendor Invoice Date"
                            tooltip="Invoice Date on Vendor Document"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'DocumentDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>

                    <ui:Column width="6rem">
                        <Label
                            text="Tax Code"
                            tooltip="Tax on Sales/Purchases Code"
                        />
                        <ui:template>
                            <Text text="{TaxCode}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="IGST"
                            tooltip="Integrated Goods and Services Tax Amount"
                        />
                        <ui:template>
                            <Text text="{igst}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="CGST"
                            tooltip="Central Goods and Services Tax Amount"
                        />
                        <ui:template>
                            <Text text="{cgst}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="SGST"
                            tooltip="State Goods and Services Tax Amount"
                        />
                        <ui:template>
                            <Text text="{sgst}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="8rem">
                        <Label
                            text="GST Amount"
                            tooltip="Total GST Amount"
                        />
                        <ui:template>
                            <Text text="{gst}" />
                        </ui:template>
                    </ui:Column>

                    <ui:Column width="9rem">
                        <Label
                            text="Invoice Amount"
                            tooltip="Total Invoice Amount in Company Currency"
                        />
                        <ui:template>
                            <Text text="{PurOrdAmountInCompanyCodeCrcy}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="9rem">
                        <Label
                            text="Payment Terms"
                            tooltip="Terms of Payment Key"
                        />
                        <ui:template>
                            <Text text="{PaymentTerms}" />
                        </ui:template>
                    </ui:Column>
                    <ui:Column width="10rem">
                        <Label
                            text="Payment Due Date"
                            tooltip="Baseline Date for Due Date Calculation"
                        />
                        <ui:template>
                            <Text
                                text="{path: 'DueCalculationBaseDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}"
                            />
                        </ui:template>
                    </ui:Column>
                </ui:columns>

                <!-- <ui:rowActionTemplate>
                    <ui:RowAction>
                        <ui:items>
                            <ui:RowActionItem type="Navigation" press=".onRowNavigate"/>
                        </ui:items>
                    </ui:RowAction>
                </ui:rowActionTemplate> -->
            </ui:Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>
